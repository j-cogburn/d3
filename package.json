{
  "name": "d3-workflow",
  "version": "2.2.0",
  "description": "Directive-Driven Development — a Claude Code workflow system",
  "bin": {
    "d3": "./bin/d3.js"
  },
  "files": [
    "bin/",
    "templates/",
    "src/",
    ".claude/commands/d3/"
  ],
  "scripts": {
    "orchestrate": "node .d3/scripts/orchestrate.js",
    "orchestrate:dry": "node .d3/scripts/orchestrate.js --dry-run",
    "run:once": "node src/scripts/d3-run.js . --once",
    "run:dry": "node src/scripts/d3-run.js . --once --dry-run",
    "learn:git": "node src/scripts/d3-learn-git.js . git",
    "index": "node src/scripts/d3-index.js .",
    "tree": "node src/scripts/d3-tree.js .",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/j-cogburn/d3.git"
  },
  "homepage": "https://github.com/j-cogburn/d3#readme",
  "keywords": [
    "claude-code",
    "ai",
    "workflow",
    "agents",
    "directive-driven-development"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2"
  }
}
